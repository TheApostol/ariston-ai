# Ariston AI — environment variables
# Copy this file to .env and fill in your values before running.
# Never commit .env to version control.

# --- AI Models ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# --- Partnerships (activate when signed) ---
HARRISON_ENABLED=false
HARRISON_API_KEY=

# --- FHIR (Epic / future) ---
FHIR_BASE_URL=
FHIR_AUTH_TOKEN=

# --- App ---
DEBUG=false
DEFAULT_MODEL=anthropic
